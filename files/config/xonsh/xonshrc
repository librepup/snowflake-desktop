# --- Keyboard ---
@events.on_ptk_create
def custom_keybindings(bindings, **kw):
    insert_mode = EmacsInsertMode() | ViInsertMode()

    @bindings.add(Keys.ControlSpace)
    def toggle_mark(event):
        buf = event.current_buffer
        if buf.selection_state:
            buf.selection_state = None
        else:
            buf.selection_state = SelectionState(
                original_cursor_position=buf.cursor_position,
                type=SelectionType.CHARACTERS
            )

    @bindings.add(Keys.Escape, 'w', filter=insert_mode)
    def emacs_copy(event):
        if event.current_buffer.selection_state:
            data = event.current_buffer.copy_selection()
            event.app.clipboard.set_data(data)
            event.current_buffer.selection_state = None
        else:
            pass

    @bindings.add(Keys.ControlY, filter=insert_mode)
    def emacs_paste(event):
        data = event.app.clipboard.get_data()
        event.current_buffer.insert_text(data.text)

    @bindings.add(Keys.ControlG)
    def cancel_action(event):
        event.current_buffer.selection_state = None

    @bindings.add(Keys.ControlL, filter=insert_mode)
    def clear_terminal(event):
        event.app.renderer.clear()

    @bindings.add(Keys.Escape, filter=insert_mode)
    def clear_line(event):
        event.current_buffer.reset()

