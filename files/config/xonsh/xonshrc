ICON_GUIX = ""
ROOT_MARK = ""

# --- Prompt Setup ---
def _shell_indicator():
    if os.getenv("IN_NIX_SHELL"):
        return ICON_NIX, "  (shell)"
    if os.getenv("GUIX_ENVIRONMENT"):
        return ICON_GUIX, "  (shell)"
    return ICON_GUIX, " "

def _user_prompt():
    icon, tag = _shell_indicator()
    try:
        cwd = str(Path.cwd()).replace(str(Path.home()), "~")
    except:
        cwd = str(Path.cwd())
    is_root = os.geteuid() == 0
    root_tag = f" ({ROOT_MARK})" if is_root else ""
    return f"{icon}{root_tag}{tag} {cwd} > "

__xonsh__.env['PROMPT'] = _user_prompt
__xonsh__.env['XONSH_SUPPRESS_WELCOME'] = True

